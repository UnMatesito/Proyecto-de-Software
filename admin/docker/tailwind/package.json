{
  "name": "proyecto-tailwind",
  "version": "1.0.0",
  "description": "Tailwind CSS para el proyecto",
  "private": true,
  "devDependencies": {
    "tailwindcss": "^3.4.0",
    "flowbite": "^1.7.5",
    "@tailwindcss/forms": "^0.5.3",
    "@tailwindcss/typography": "^0.5.9",
    "postcss": "^8.4.32",
    "autoprefixer": "^10.4.14"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.5.2"
  },
  "scripts": {
    "build": "tailwindcss -i ./input.css -o /app/static/css/styles.css --minify",
    "build-dev": "tailwindcss -i ./input.css -o /app/static/css/styles.css",
    "watch": "tailwindcss -i ./input.css -o /app/static/css/styles.css --watch --poll --minify",
    "watch-dev": "tailwindcss -i ./input.css -o /app/static/css/styles.css --watch --poll"
  }
}