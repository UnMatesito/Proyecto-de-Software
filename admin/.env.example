# Entorno de desarrollo
FLASK_ENV=development

# Base de datos
DATABASE_URL=COMPLETAR

# Clave secreta
SECRET_KEY=COMPLETAR

# Activar debugging
DEBUG=False

# Configuración de sesión
SESSION_TYPE=filesystem

# Configuración de PostgreSQL
POSTGRES_USER=COMPLETAR
POSTGRES_PASSWORD=COMPLETAR
POSTGRES_DB=proyecto_db

# Configuración de MinIO
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=proyecto
MINIO_ACCESS_KEY=COMPLETAR
MINIO_SECRET_KEY=COMPLETAR
MINIO_SECURE=False

# Configuración de JWT
JWT_SECRET_KEY=COMPLETAR

# Google OAuth Configuración
GOOGLE_CLIENT_ID=COMPLETAR
GOOGLE_CLIENT_SECRET=COMPLETAR
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# URL del frontend
FRONTEND_URL=http://localhost:5173